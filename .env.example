# Supabase auth configuration
# Copy this file to .env and replace placeholders.
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key
# Optional alias for newer Supabase naming:
# SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# OpenAI configuration (Phase 2)
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# Stripe billing links (Phase 3)
STRIPE_PREMIUM_CHECKOUT_URL=https://buy.stripe.com/your-checkout-link
STRIPE_CUSTOMER_PORTAL_URL=https://billing.stripe.com/p/login/your-portal-link

# Optional developer bypass for local testing
# MEMORA_PREMIUM_BETA=true
