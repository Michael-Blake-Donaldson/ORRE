{
  "name": "orre",
  "private": true,
  "version": "0.0.0",
  "description": "Memora - AI screen memory for Windows",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "npm run rebuild:native && npm run build:electron && electron .",
    "postinstall": "npm run rebuild:native",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build": "npm run build:electron",
    "start": "npm run dev"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "ffmpeg-static": "^5.3.0",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.12.0",
    "electron": "^36.5.0",
    "typescript": "~5.9.3"
  }
}
